.venv
__pycache__/
*.pyc
*.egg-info/
# Model weights and tokenizer files (large)
**/checkpoint-*/
**/*.safetensors
**/*.bin
**/tokenizer.json
**/tokenizer_config.json
**/special_tokens_map.json
**/added_tokens.json
**/vocab.json
**/merges.txt
**/chat_template.jinja
**/README.md
**/training_args.bin
**/adapter_config.json
**/adapter_model.safetensors
# Keep only JSON results, configs, scripts, logs
!configs/*.yaml
!results/**/*metrics*.json
!results/**/*telemetry*.json
!results/**/*logs*.json
!results/**/*stats*.json
!results/**/eval_*.json
!results/**/*calibration*.json
!results/**/*accuracy*.json
!results/**/*analysis*.json
!results/**/*predictor*.json
!results/**/*variant*.json
!results/**/*boundaries*.json
!results/**/*points*.json
